{"responses":{"200":{"description":"OK","headers":{"Link":{"description":"RFC 5988 pagination links. A comma-separated list of URL/relation pairs for\n`prev`, `next`, and (on length-aware paginators) `first` / `last`. Follow\n`rel=\"next\"` until it is absent to iterate a list.","schema":{"type":"string"},"example":"<https://identity.eurofurence.org/api/v2/groups/Y6K08PEKXG9Q7ZWJ/members?page=3>; rel=\"next\", <https://identity.eurofurence.org/api/v2/groups/Y6K08PEKXG9Q7ZWJ/members?page=1>; rel=\"prev\""},"X-Per-Page":{"description":"Number of items per page.","schema":{"type":"integer"},"example":25},"X-Current-Page":{"description":"The current page number (1-based).","schema":{"type":"integer"},"example":2}},"content":{"application/json":{"schema":{"type":"array","items":{"type":"object","properties":{"user_id":{"type":"string","example":"1VJEQAYWW54TZ5VD"},"name":{"type":"string","example":"John Doe"},"email":{"type":"string","nullable":true,"description":"Email (only visible with `view_full_staff_details` scope)"},"avatar":{"type":"string","nullable":true,"description":"Avatar URL"},"level":{"type":"string","enum":["member","team_lead","director","division_director"],"example":"member"},"title":{"type":"string","nullable":true,"example":"App Developer"},"credit_as":{"type":"string","nullable":true,"example":"J. Doe"}},"title":"GroupMember"}}}}}}}