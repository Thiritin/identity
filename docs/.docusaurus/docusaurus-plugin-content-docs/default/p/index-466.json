chemas/groupsummary","title":"GroupSummary","description":"Nested group (parent or child) without recursive relations","sidebar":"identitySidebar"},"identity/api/v2/schemas/grouptreenode":{"id":"identity/api/v2/schemas/grouptreenode","title":"GroupTreeNode","description":"Recursive tree node representing a group in the hierarchy","sidebar":"identitySidebar"},"identity/api/v2/schemas/jsonwebkeyset":{"id":"identity/api/v2/schemas/jsonwebkeyset","title":"JSONWebKeySet","description":"","sidebar":"identitySidebar"},"identity/api/v2/schemas/metadata":{"id":"identity/api/v2/schemas/metadata","title":"Metadata","description":"","sidebar":"identitySidebar"},"identity/api/v2/schemas/metadatavalue":{"id":"identity/api/v2/schemas/metadatavalue","title":"MetadataValue","description":"","sidebar":"identitySidebar"},"identity/api/v2/schemas/oautherror":{"id":"identity/api/v2/schemas/oautherror","title":"OAuthError","description":"","sidebar":"identitySidebar"},"identity/api/v2/schemas/openidconfiguration":{"id":"identity/api/v2/schemas/openidconfiguration","title":"OpenIDConfiguration","description":"","sidebar":"identitySidebar"},"identity/api/v2/schemas/staffprofile":{"id":"identity/api/v2/schemas/staffprofile","title":"StaffProfile","description":"Staff member profile. PII fields may be absent based on the viewer's relationship to the staff member.","sidebar":"identitySidebar"},"identity/api/v2/schemas/tokenintrospectionrequest":{"id":"identity/api/v2/schemas/tokenintrospectionrequest","title":"TokenIntrospectionRequest","description":"","sidebar":"identitySidebar"},"identity/api/v2/schemas/tokenintrospectionresponse":{"id":"identity/api/v2/schemas/tokenintrospectionresponse","title":"TokenIntrospectionResponse","description":"","sidebar":"identitySidebar"},"identity/api/v2/schemas/tokenrequest":{"id":"identity/api/v2/schemas/tokenrequest","title":"TokenRequest","description":"","sidebar":"identitySidebar"},"identity/api/v2/schemas/tokenresponse":{"id":"identity/api/v2/schemas/tokenresponse","title":"TokenResponse","description":"","sidebar":"identitySidebar"},"identity/api/v2/schemas/updatememberform":{"id":"identity/api/v2/schemas/updatememberform","title":"UpdateMemberForm","description":"","sidebar":"identitySidebar"},"identity/api/v2/schemas/userinfo":{"id":"identity/api/v2/schemas/userinfo","title":"Userinfo","description":"","sidebar":"identitySidebar"},"identity/api/v2/staff":{"id":"identity/api/v2/staff","title":"Staff","description":"Staff","sidebar":"identitySidebar"},"identity/api/v2/update-group":{"id":"identity/api/v2/update-group","title":"Update group","description":"Update group","sidebar":"identitySidebar"},"identity/api/v2/update-group-member":{"id":"identity/api/v2/update-group-member","title":"Update member","description":"Update a member's level or title within a group.","sidebar":"identitySidebar"},"identity/api/v2/user-metadata":{"id":"identity/api/v2/user-metadata","title":"User Metadata","description":"User Metadata","sidebar":"identitySidebar"},"identity/guides/app-to-app":{"id":"identity/guides/app-to-app","title":"App-to-App APIs","description":"Eurofurence services need to talk to each other. The registration system might need to check group memberships via Identity, or the Dealer's Den might need to verify a registration status. This guide explains how service-to-service communication is secured.","sidebar":"identitySidebar"},"identity/guides/audiences":{"id":"identity/guides/audiences","title":"Audiences","description":"Audiences control where a token can be used. While scopes define what an app can do, audiences define which service should accept the token. This prevents a token meant for one service from being replayed against another.","sidebar":"identitySidebar"},"identity/guides/build-an-application":{"id":"identity/guides/build-an-application","title":"Build an Application","description":"This guide explains how to integrate your application with Eurofurence Identity for authentication and authorization.","sidebar":"identitySidebar"},"identity/guides/getting-started":{"id":"identity/guides/getting-started","title":"Getting Started","description":"This guide walks you through the basics of integrating with Eurofurence Identity, from understanding how authentication works to making your first API call.","sidebar":"identitySidebar"},"identity/guides/scopes":{"id":"identity/guides/scopes","title":"Scopes","description":"Scopes control what data and APIs your application can access on behalf of a user. When a user authorizes your app, they see which scopes you're requesting and can decide whether to grant access.","sidebar":"identitySidebar"},"identity/guides/tokens":{"id":"identity/guides/tokens","title":"Understanding Tokens","description":"After a successful login, Eurofurence Identity hands your application up to three different tokens. They look similar but serve very different purposes, and mixing them up is one of the most common sources of bugs and security issues. This page explains what each token is for, who is supposed to verify it, and how to use it correctly.","sidebar":"identitySidebar"},"identity/index":{"id":"identity/index","title":"Introduction","description":"Eurofurence Identity is the central authentication and authorization service for the Eurofurence ecosystem. It allows users to sign in once and access all connected Eurofurence applications, from event registration to community tools, with a single account.","sidebar":"identitySidebar"}}}}