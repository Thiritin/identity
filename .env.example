##########################################################
# App
##########################################################

APP_NAME=Identity
APP_ENV=local
APP_DEBUG=true
APP_URL=http://identity.eurofurence.localhost/

# Pre-generated for convenience. Generate your own with: php artisan key:generate
APP_KEY=base64:xoIA1IBbUjD3w1PvYYjakHYrkH3lyHPgy4ctYvAiwAw=

##########################################################
# Hashids (used for obfuscating public IDs)
# Generate your own with: openssl rand -hex 32
##########################################################

HASHIDS_SALT=f9931717d231b7578668faedccce718c9cc9769af5fdf7ae1b8b3800241fc074
HASHIDS_USER_SALT=5588ab6d9b4ffbaf4e21e93faf6feb612814364c093a56ad440e2df5816e3567
HASHIDS_GROUP_SALT=20890ee95f76d3c8cb334359f2f9842d5fa31d4802e1f0e8dd033756017d979c

##########################################################
# Logging
##########################################################

LOG_CHANNEL=stack
LOG_LEVEL=debug

##########################################################
# Database (MySQL)
##########################################################

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=sail
DB_PASSWORD=password

##########################################################
# Cache, Queue, Session
##########################################################

BROADCAST_DRIVER=log
CACHE_DRIVER=redis
FILESYSTEM_DRIVER=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=database
SESSION_LIFETIME=120

##########################################################
# Redis
##########################################################

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

##########################################################
# Mail (Mailpit - accessible at http://localhost:8025)
##########################################################

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=noreply@identity.eurofurence.localhost
MAIL_FROM_NAME="${APP_NAME}"

##########################################################
# Hydra (OAuth2 / OpenID Connect server)
# Portal/Admin/Staff IDs and secrets are created by the
# database seeder — leave these empty for first-time setup.
##########################################################

IDENTITY_OPENID_CONFIGURATION=http://identity.eurofurence.localhost/.well-known/openid-configuration
HYDRA_PUBLIC_URL=http://hydra:4444
HYDRA_ADMIN_URL=http://hydra:4445/

# Pre-generated for convenience. Generate your own with: openssl rand -hex 32
HYDRA_SECRET_KEY=2f8a4f1ad33752b26891beb16ea52640aa080142e77cf2fcd26af08fa25201d3

IDENTITY_PORTAL_CALLBACK_URL=http://identity.eurofurence.localhost/auth/portal/callback
IDENTITY_PORTAL_ID=
IDENTITY_PORTAL_SECRET=

IDENTITY_ADMIN_CALLBACK_URL=http://identity.eurofurence.localhost/auth/admin/callback
IDENTITY_ADMIN_ID=
IDENTITY_ADMIN_SECRET=

IDENTITY_STAFF_CALLBACK_URL=http://identity.eurofurence.localhost/auth/staff/callback
IDENTITY_STAFF_ID=
IDENTITY_STAFF_SECRET=

##########################################################
# Registration Attendee Service
##########################################################

REG_ATTENDEE_SERVICE_URL=
REG_ATTENDEE_SERVICE_TOKEN=

##########################################################
# EDNA (NDA verification)
##########################################################

EDNA_URL=

##########################################################
# Pusher (WebSockets)
##########################################################

PUSHER_APP_ID=ef-identity
PUSHER_APP_KEY=ef-identity
PUSHER_APP_SECRET=some-default-secret-key-for-dev-environment
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

##########################################################
# ALTCHA (captcha)
##########################################################

ALTCHA_HMAC_KEY=
ALTCHA_TESTING_BYPASS=

##########################################################
# Telegram Bot (optional)
##########################################################

TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=EurofurenceBot

##########################################################
# Seeder defaults
##########################################################

# Password for the admin user created by db:seed
ADMIN_PASSWORD=admin

##########################################################
# Docker / Sail settings
# Uncomment and adjust if file permissions are wrong.
# Run `id -u` and `id -g` to find your UID/GID.
##########################################################

#WWWUSER=1000
#WWWGROUP=1000
#WWWUSERNAME=sail

##########################################################
# Dev server command (runs inside the container)
# Defaults to `php artisan serve`. Alternatives:
#   DEV_SERVER_COMMAND="php artisan octane:start --host=0.0.0.0 --port=80 --watch"
#   DEV_SERVER_COMMAND="tail -F /dev/null"   # no-op, useful for debugging
##########################################################

#DEV_SERVER_COMMAND="php -d variables_order=EGPCS /var/www/html/artisan serve --host=0.0.0.0 --port=80"

##########################################################
# AWS S3 (optional, not needed for local development)
##########################################################

#AWS_ACCESS_KEY_ID=
#AWS_SECRET_ACCESS_KEY=
#AWS_DEFAULT_REGION=us-east-1
# General-purpose S3 bucket (distinct from AWS_BUCKET_AVATARS for legacy avatar storage)
AWS_BUCKET=
#AWS_USE_PATH_STYLE_ENDPOINT=false
